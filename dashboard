// ═══════════════════ STATE ═══════════════════
function loadData() {
  return {
    rate: parseFloat(localStorage.getItem('rdb_rate') || DEFAULT_RATE),
    inkoop: JSON.parse(localStorage.getItem('rdb_inkoop') || 'null') || JSON.parse(JSON.stringify(DEFAULT_INKOOP)),
    vinted: JSON.parse(localStorage.getItem('rdb_vinted') || 'null') || JSON.parse(JSON.stringify(DEFAULT_VINTED)),
  };
}
function saveData() {
  localStorage.setItem('rdb_rate', D.rate);
  localStorage.setItem('rdb_inkoop', JSON.stringify(D.inkoop));
  localStorage.setItem('rdb_vinted', JSON.stringify(D.vinted));
}
let D = loadData();

// ═══════════════════ HELPERS ═══════════════════
const eur = n => '€' + n.toFixed(2).replace('.',',');
const cny = n => '¥' + Math.round(n).toLocaleString('nl');
function badge(cat) { return `<span class="badge b-${cat}">${cat}</span>`; }
function monthlyData() {
  const m = {};
  D.inkoop.forEach(r => { const k=r[0].slice(0,7); m[k]=m[k]||{b:0,v:0}; m[k].b+=r[5]*r[6]*D.rate; });
  D.vinted.forEach(r => { const k=r[0].slice(0,7); m[k]=m[k]||{b:0,v:0}; m[k].v+=r[3]; });
  return m;
}

// ═══════════════════ DELETE MODAL ═══════════════════
let pendingDelete = null;
function askDelete(type, idx, label) {
  pendingDelete = { type, idx };
  document.getElementById('modal-title').textContent = (type==='vinted'?'💰':'📥') + ' Regel verwijderen?';
  document.getElementById('modal-sub').textContent = label;
  document.getElementById('modal').classList.add('open');
}
function closeModal() {
  document.getElementById('modal').classList.remove('open');
  pendingDelete = null;
}
function confirmDelete() {
  if (!pendingDelete) return;
  if (pendingDelete.type === 'inkoop') D.inkoop.splice(pendingDelete.idx, 1);
  else D.vinted.splice(pendingDelete.idx, 1);
  saveData();
  closeModal();
  renderAll();
  toast('🗑 Verwijderd — alles bijgewerkt');
}
document.getElementById('modal').addEventListener('click', e => { if(e.target===e.currentTarget) closeModal(); });

// ═══════════════════ RENDER KPIs ═══════════════════
function renderKPIs() {
  const totCNY = D.inkoop.reduce((s,r)=>s+r[5]*r[6],0);
  const totEUR = totCNY * D.rate;
  const totV   = D.vinted.reduce((s,r)=>s+r[3],0);
  const winst  = totV - totEUR;
  const marge  = totEUR>0 ? (winst/totEUR*100) : 0;
  const stuks  = D.inkoop.reduce((s,r)=>s+r[5],0);
  const wc     = winst>=0 ? 'var(--grn)' : 'var(--red)';
  document.getElementById('kpi-grid').innerHTML = `
    <div class="kpi-card">
      <div class="kpi-label">Totale Inkoop</div>
      <div class="kpi-value" style="font-size:17px">${cny(totCNY)}</div>
      <div class="kpi-sub">${eur(totEUR)}</div>
    </div>
    <div class="kpi-card teal">
      <div class="kpi-label">Vinted Opbrengst</div>
      <div class="kpi-value">${eur(totV)}</div>
      <div class="kpi-sub">${D.vinted.length} verkopen</div>
    </div>
    <div class="kpi-card grn">
      <div class="kpi-label">Bruto Winst</div>
      <div class="kpi-value" style="color:${wc}">${eur(winst)}</div>
      <div class="kpi-sub">Marge: ${marge.toFixed(1)}%</div>
    </div>
    <div class="kpi-card org">
      <div class="kpi-label">Stuks Ingekocht</div>
      <div class="kpi-value">${stuks}</div>
      <div class="kpi-sub">${D.inkoop.length} regels</div>
    </div>`;
}

// ═══════════════════ RENDER CHARTS ═══════════════════
let barC, pieC;
function renderCharts() {
  const m = monthlyData();
  const keys = Object.keys(m).sort();
  const labels = keys.map(k => k.slice(5)+'/'+k.slice(2,4));
  const bVals = keys.map(k => +m[k].b.toFixed(2));
  const vVals = keys.map(k => +m[k].v.toFixed(2));
  if (barC) barC.destroy();
  barC = new Chart(document.getElementById('barChart'), {
    type:'bar', data:{ labels,
      datasets:[
        {label:'Inkoop €',data:bVals,backgroundColor:'#4F8EF7',borderRadius:4},
        {label:'Vinted €',data:vVals,backgroundColor:'#09B1AA',borderRadius:4}
      ]},
    options:{responsive:true,plugins:{legend:{position:'top'}},
      scales:{y:{ticks:{callback:v=>'€'+v}}}}
  });
  const cats={};
  D.vinted.forEach(r=>{cats[r[1]]=(cats[r[1]]||0)+r[3];});
  const cl=Object.keys(cats).sort((a,b)=>cats[b]-cats[a]), cv=cl.map(c=>+cats[c].toFixed(2));
  if (pieC) pieC.destroy();
  pieC = new Chart(document.getElementById('pieChart'), {
    type:'doughnut', data:{labels:cl,
      datasets:[{data:cv,backgroundColor:['#4F8EF7','#7C5CFC','#3EC9CF','#FF7B54','#47C98F','#F76B8A'],borderWidth:2}]},
    options:{responsive:true,plugins:{legend:{position:'bottom'}}}
  });
}

// ═══════════════════ RENDER MAANDEN ═══════════════════
function renderMaanden() {
  const m = monthlyData();
  const keys = Object.keys(m).sort();
  let tb=0,tv=0,html='';
  keys.forEach((k,i)=>{
    const b=m[k].b,v=m[k].v,w=v-b,mg=b>0?(w/b*100).toFixed(1):'-';
    tb+=b; tv+=v;
    const wc=w>=0?'var(--grn)':'var(--red)';
    html+=`<div class="month-row ${i%2?'alt':''}">
      <div class="m-maand">${k.slice(5)+'/'+k.slice(2,4)}</div>
      <div class="m-buy">${eur(b)}</div>
      <div class="m-vint">${eur(v)}</div>
      <div class="m-winst" style="color:${wc}">${eur(w)}</div>
      <div class="m-pct">${mg}%</div>
    </div>`;
  });
  const tw=tv-tb,wc2=tw>=0?'#47C98F':'#ff6b6b';
  html+=`<div class="month-row tot">
    <div class="m-maand">TOT</div>
    <div class="m-buy">${eur(tb)}</div>
    <div class="m-vint">${eur(tv)}</div>
    <div class="m-winst" style="color:${wc2}">${eur(tw)}</div>
    <div class="m-pct">${tb>0?(tw/tb*100).toFixed(1):0}%</div>
  </div>`;
  document.getElementById('maand-rows').innerHTML = html;
}

// ═══════════════════ RENDER INKOOP ═══════════════════
function renderInkoop() {
  const q = (document.getElementById('inkoop-search')?.value||'').toLowerCase();
  // Sort newest first, keep original index for deletion
  const indexed = D.inkoop.map((r,i)=>({r,i})).sort((a,b)=>b.r[0].localeCompare(a.r[0]));
  const filtered = q ? indexed.filter(({r})=>r[3].toLowerCase().includes(q)||r[1].toLowerCase().includes(q)) : indexed;
  document.getElementById('inkoop-count').textContent = `${filtered.length} regels · ${eur(filtered.reduce((s,{r})=>s+r[5]*r[6]*D.rate,0))}`;
  let html='';
  filtered.forEach(({r,i},fi)=>{
    const e=r[5]*r[6]*D.rate;
    html+=`<div class="list-item ${fi%2?'alt':''}">
      <div class="list-item-body">
        <div class="li-top">
          <span class="li-date">${r[0].slice(5)}</span>
          ${badge(r[1])}
          <span class="li-art">${r[3]}</span>
        </div>
        <div class="li-bottom">
          <span class="li-maat">${r[4]}</span>
          ${r[5]>1?`<span class="li-qty">${r[5]}×</span>`:''}
          <span style="font-size:10px;color:var(--greyt)">¥${r[6]}/stk</span>
        </div>
      </div>
      <span class="li-amt blue">${eur(e)}</span>
      <button class="del-btn" onclick="askDelete('inkoop',${i},'${r[3].replace(/'/g,"\\'")} · ${r[0]}')">×</button>
    </div>`;
  });
  document.getElementById('inkoop-list').innerHTML = html || '<div style="padding:20px;text-align:center;color:var(--greyt)">Geen resultaten</div>';
}

// ═══════════════════ RENDER VINTED ═══════════════════
function renderVinted() {
  const q = (document.getElementById('vinted-search')?.value||'').toLowerCase();
  const indexed = D.vinted.map((r,i)=>({r,i})).sort((a,b)=>b.r[0].localeCompare(a.r[0]));
  const filtered = q ? indexed.filter(({r})=>(r[2]||'').toLowerCase().includes(q)||r[1].toLowerCase().includes(q)) : indexed;
  document.getElementById('vinted-count').textContent = `${filtered.length} verkopen · ${eur(filtered.reduce((s,{r})=>s+r[3],0))}`;
  let html='';
  filtered.forEach(({r,i},fi)=>{
    html+=`<div class="list-item ${fi%2?'alt':''}">
      <div class="list-item-body">
        <div class="li-top">
          <span class="li-date">${r[0].slice(5)}</span>
          ${badge(r[1])}
          <span class="li-art">${r[2]||'('+r[1]+')'}</span>
        </div>
      </div>
      <span class="li-amt teal">${eur(r[3])}</span>
      <button class="del-btn" onclick="askDelete('vinted',${i},'${(r[2]||r[1]).replace(/'/g,"\\'")} · ${r[0]}')">×</button>
    </div>`;
  });
  document.getElementById('vinted-list').innerHTML = html || '<div style="padding:20px;text-align:center;color:var(--greyt)">Geen resultaten</div>';
}

// ═══════════════════ ADD ═══════════════════
function addVinted() {
  const d=document.getElementById('v-datum').value;
  const cat=document.getElementById('v-cat').value;
  const e=parseFloat(document.getElementById('v-eur').value);
  const art=document.getElementById('v-art').value.trim();
  if(!d||isNaN(e)||e<=0){toast('Vul datum en bedrag in ⚠️');return;}
  D.vinted.push([d,cat,art,e]);
  saveData(); renderAll();
  document.getElementById('v-eur').value='';
  document.getElementById('v-art').value='';
  toast('✓ Verkoop toegevoegd & winst bijgewerkt!');
}

function addInkoop() {
  const d=document.getElementById('i-datum').value;
  const cat=document.getElementById('i-cat').value;
  const plat=document.getElementById('i-plat').value;
  const art=document.getElementById('i-art').value.trim();
  const maat=document.getElementById('i-maat').value.trim();
  const qty=parseInt(document.getElementById('i-qty').value)||1;
  const prijs=parseFloat(document.getElementById('i-prijs').value);
  if(!d||isNaN(prijs)||prijs<=0){toast('Vul datum en prijs in ⚠️');return;}
  D.inkoop.push([d,cat,plat,art,maat,qty,prijs]);
  saveData(); renderAll();
  document.getElementById('i-art').value='';
  document.getElementById('i-maat').value='';
  document.getElementById('i-qty').value='1';
  document.getElementById('i-prijs').value='';
  toast('✓ Inkoop toegevoegd & dashboard bijgewerkt!');
}

function saveRate() {
  const r=parseFloat(document.getElementById('eur-rate').value);
  if(isNaN(r)||r<=0){toast('Ongeldige koers ⚠️');return;}
  D.rate=r; saveData(); renderAll();
  toast('✓ Wisselkoers opgeslagen!');
}

function confirmReset() {
  if(!confirm('Weet je zeker dat je ALLES wilt resetten? Dit verwijdert ook je eigen toevoegingen.')) return;
  localStorage.removeItem('rdb_rate');
  localStorage.removeItem('rdb_inkoop');
  localStorage.removeItem('rdb_vinted');
  D=loadData(); renderAll();
  toast('Data teruggezet naar standaard');
}

// ═══════════════════ TOAST ═══════════════════
function toast(msg) {
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2800);
}

// ═══════════════════ NAV ═══════════════════
function showPage(name, el) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  if(el) el.classList.add('active');
  if(name==='overview'){renderKPIs();renderCharts();}
  if(name==='maanden') renderMaanden();
  if(name==='inkoop')  renderInkoop();
  if(name==='vinted')  renderVinted();
}

function renderAll() {
  renderKPIs(); renderCharts(); renderMaanden(); renderInkoop(); renderVinted();
}

// ═══════════════════ INIT ═══════════════════
const today=new Date().toISOString().slice(0,10);
document.getElementById('v-datum').value=today;
document.getElementById('i-datum').value=today;
document.getElementById('eur-rate').value=D.rate;
renderAll();
