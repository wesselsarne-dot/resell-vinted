<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Resell Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  :root {
    --bg:#F5F6FA; --white:#FFFFFF; --navy:#1E2A4A;
    --blue:#4F8EF7; --purp:#7C5CFC; --teal:#3EC9CF;
    --org:#FF7B54; --grn:#47C98F; --pink:#F76B8A; --vint:#09B1AA;
    --grey1:#F0F2F8; --grey2:#E0E4F0; --greyt:#8A94B0;
    --dark:#2D3A5C; --mid:#4A5578;
    --red:#dc2626; --red-lt:#fee2e2;
  }
  *{box-sizing:border-box;margin:0;padding:0;font-family:-apple-system,'Helvetica Neue',sans-serif;-webkit-tap-highlight-color:transparent;}
  body{background:var(--bg);min-height:100vh;padding-bottom:80px;}

  /* HEADER */
  .header{background:var(--navy);color:white;padding:18px 16px 14px;}
  .header h1{font-size:19px;font-weight:800;letter-spacing:.4px;}
  .header p{font-size:10px;color:#8A94B0;margin-top:3px;}

  /* BOTTOM NAV */
  .bottom-nav{position:fixed;bottom:0;left:0;right:0;background:var(--navy);display:flex;border-top:1px solid #2D3A5C;z-index:100;padding-bottom:env(safe-area-inset-bottom);}
  .tab{flex:1;padding:10px 2px 8px;text-align:center;font-size:9px;color:#8A94B0;cursor:pointer;border-top:2px solid transparent;display:flex;flex-direction:column;align-items:center;gap:2px;}
  .tab-icon{font-size:18px;line-height:1;}
  .tab.active{color:var(--blue);border-top-color:var(--blue);}

  /* PAGES */
  .page{display:none;padding:12px;}
  .page.active{display:block;}

  /* KPI */
  .kpi-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
  .kpi-card{background:var(--white);border-radius:12px;padding:13px 12px;border-top:3px solid var(--blue);box-shadow:0 1px 6px rgba(0,0,0,.06);}
  .kpi-card.teal{border-top-color:var(--vint);}
  .kpi-card.grn{border-top-color:var(--grn);}
  .kpi-card.org{border-top-color:var(--org);}
  .kpi-card.purp{border-top-color:var(--purp);}
  .kpi-label{font-size:9px;font-weight:700;color:var(--greyt);text-transform:uppercase;letter-spacing:.5px;margin-bottom:5px;}
  .kpi-value{font-size:20px;font-weight:800;color:var(--blue);}
  .kpi-card.teal .kpi-value{color:var(--vint);}
  .kpi-card.grn .kpi-value{color:var(--grn);}
  .kpi-card.org .kpi-value{color:var(--org);}
  .kpi-sub{font-size:10px;color:var(--greyt);margin-top:2px;}
  .kpi-wide{grid-column:1/-1;}

  /* SECTION */
  .section-title{font-size:12px;font-weight:700;color:var(--navy);padding:10px 0 6px;border-bottom:2px solid var(--blue);margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;}
  .section-sub{font-size:10px;font-weight:400;color:var(--greyt);}

  /* CHART */
  .chart-wrap{background:var(--white);border-radius:12px;padding:14px;margin-bottom:12px;box-shadow:0 1px 6px rgba(0,0,0,.06);}
  .chart-title{font-size:11px;font-weight:700;color:var(--navy);margin-bottom:10px;}

  /* MONTH TABLE */
  .table-wrap{background:var(--white);border-radius:10px;overflow:hidden;box-shadow:0 1px 6px rgba(0,0,0,.06);margin-bottom:14px;}
  .month-row{display:flex;padding:9px 12px;border-bottom:1px solid var(--grey2);font-size:11px;align-items:center;}
  .month-row:last-child{border-bottom:none;}
  .month-row.hdr{background:var(--navy);color:white;font-weight:700;font-size:10px;padding:8px 12px;}
  .month-row.tot{background:var(--navy);color:white;font-weight:700;font-size:12px;}
  .month-row.alt{background:var(--grey1);}
  .m-maand{width:46px;font-weight:700;color:var(--dark);flex-shrink:0;}
  .m-buy{width:64px;color:var(--blue);text-align:right;flex-shrink:0;}
  .m-vint{width:64px;color:var(--vint);text-align:right;flex-shrink:0;}
  .m-winst{width:64px;text-align:right;font-weight:700;flex-shrink:0;}
  .m-pct{flex:1;text-align:right;color:var(--greyt);font-size:10px;}

  /* LIST ROWS — swipe-to-delete style with delete button */
  .list-item{position:relative;display:flex;align-items:center;padding:10px 12px;border-bottom:1px solid var(--grey2);font-size:12px;background:var(--white);transition:background .15s;}
  .list-item:last-child{border-bottom:none;}
  .list-item.alt{background:var(--grey1);}
  .list-item-body{flex:1;min-width:0;}
  .li-top{display:flex;align-items:center;gap:6px;margin-bottom:2px;}
  .li-date{font-size:10px;color:var(--greyt);flex-shrink:0;}
  .li-art{font-size:12px;color:var(--dark);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .li-bottom{display:flex;align-items:center;gap:6px;}
  .li-maat{font-size:10px;color:var(--purp);font-weight:600;}
  .li-qty{font-size:10px;color:var(--org);font-weight:700;}
  .li-amt{font-size:14px;font-weight:800;flex-shrink:0;margin-left:8px;}
  .li-amt.blue{color:var(--blue);}
  .li-amt.teal{color:var(--vint);}
  .del-btn{width:34px;height:34px;border:none;background:var(--red-lt);color:var(--red);border-radius:8px;font-size:18px;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;margin-left:8px;font-weight:700;}
  .del-btn:active{background:#fecaca;}

  /* BADGE */
  .badge{display:inline-block;padding:1px 6px;border-radius:20px;font-size:9px;font-weight:700;}
  .b-Schoenen{background:#EBF2FF;color:var(--blue);}
  .b-Kleding{background:#F0EBFF;color:var(--purp);}
  .b-Voetbalshirts{background:#E6F9FA;color:var(--teal);}
  .b-Tassen{background:#FFF0EB;color:var(--org);}
  .b-Accessoires{background:#EAFAF3;color:var(--grn);}
  .b-Overige{background:#FFF0F4;color:var(--pink);}

  /* FORMS */
  .form-card{background:var(--white);border-radius:12px;padding:16px;margin-bottom:14px;box-shadow:0 1px 6px rgba(0,0,0,.06);}
  .form-title{font-size:13px;font-weight:700;color:var(--navy);margin-bottom:12px;padding-bottom:8px;border-bottom:2px solid var(--grey2);}
  .form-row{margin-bottom:10px;}
  .form-row label{display:block;font-size:11px;font-weight:600;color:var(--mid);margin-bottom:4px;}
  .form-row input,.form-row select{width:100%;padding:10px 11px;border:1.5px solid var(--grey2);border-radius:8px;font-size:14px;color:var(--dark);background:var(--bg);outline:none;-webkit-appearance:none;}
  .form-row input:focus,.form-row select:focus{border-color:var(--blue);background:var(--white);}
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
  .btn{width:100%;padding:13px;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;}
  .btn-blue{background:var(--blue);color:white;}
  .btn-teal{background:var(--vint);color:white;}
  .btn-red{background:var(--red-lt);color:var(--red);font-size:12px;padding:10px;margin-top:8px;}
  .btn:active{opacity:.85;}

  /* SETTING */
  .setting-row{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;background:var(--white);border-radius:10px;margin-bottom:8px;box-shadow:0 1px 4px rgba(0,0,0,.05);}
  .setting-input{width:100px;padding:7px 9px;border:1.5px solid var(--grey2);border-radius:7px;font-size:14px;text-align:right;color:var(--blue);font-weight:700;background:var(--bg);}

  /* MODAL */
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;display:none;align-items:flex-end;justify-content:center;}
  .modal-overlay.open{display:flex;}
  .modal{background:var(--white);border-radius:20px 20px 0 0;padding:20px 16px 30px;width:100%;max-width:480px;}
  .modal-title{font-size:16px;font-weight:700;color:var(--navy);margin-bottom:6px;}
  .modal-sub{font-size:13px;color:var(--greyt);margin-bottom:16px;}
  .modal-btns{display:flex;gap:10px;}
  .modal-btns .btn{flex:1;}

  /* TOAST */
  .toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:var(--navy);color:white;padding:10px 22px;border-radius:20px;font-size:13px;font-weight:600;z-index:300;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;}
  .toast.show{opacity:1;}

  /* SEARCH */
  .search-bar{width:100%;padding:9px 12px;border:1.5px solid var(--grey2);border-radius:10px;font-size:13px;background:var(--white);margin-bottom:10px;outline:none;}
  .search-bar:focus{border-color:var(--blue);}

  .hdr-row{background:var(--navy);color:white;font-size:10px;font-weight:700;padding:8px 12px;display:flex;gap:8px;}
</style>
</head>
<body>

<div class="header">
  <h1>◆ RESELL DASHBOARD</h1>
  <p>Basetao inkoop · Vinted verkopen · Live winst bijgewerkt</p>
</div>

<!-- PAGES -->
<div id="page-overview" class="page active">
  <div class="kpi-grid" id="kpi-grid"></div>
  <div class="chart-wrap">
    <div class="chart-title">Inkoop vs Vinted per maand (€)</div>
    <canvas id="barChart" height="210"></canvas>
  </div>
  <div class="chart-wrap">
    <div class="chart-title">Verdeling Vinted verkopen per categorie</div>
    <canvas id="pieChart" height="210"></canvas>
  </div>
</div>

<div id="page-maanden" class="page">
  <div class="section-title">Maandoverzicht <span class="section-sub">inkoop · vinted · winst</span></div>
  <div class="table-wrap">
    <div class="month-row hdr">
      <div class="m-maand">Maand</div>
      <div class="m-buy">Inkoop</div>
      <div class="m-vint">Vinted</div>
      <div class="m-winst">Winst</div>
      <div class="m-pct">%</div>
    </div>
    <div id="maand-rows"></div>
  </div>
</div>

<div id="page-inkoop" class="page">
  <div class="section-title">
    Inkoop <span class="section-sub" id="inkoop-count"></span>
  </div>
  <input class="search-bar" type="search" placeholder="🔍 Zoek artikel..." id="inkoop-search" oninput="renderInkoop()">
  <div id="inkoop-list"></div>
</div>

<div id="page-vinted" class="page">
  <div class="section-title">
    Vinted <span class="section-sub" id="vinted-count"></span>
  </div>
  <input class="search-bar" type="search" placeholder="🔍 Zoek artikel..." id="vinted-search" oninput="renderVinted()">
  <div id="vinted-list"></div>
</div>

<div id="page-add" class="page">
  <!-- VINTED -->
  <div class="form-card">
    <div class="form-title">💰 Vinted verkoop toevoegen</div>
    <div class="form-row"><label>Datum</label><input type="date" id="v-datum"></div>
    <div class="form-grid">
      <div class="form-row">
        <label>Categorie</label>
        <select id="v-cat"><option>Schoenen</option><option>Kleding</option><option>Tassen</option><option>Accessoires</option><option>Overige</option></select>
      </div>
      <div class="form-row"><label>Opbrengst €</label><input type="number" id="v-eur" placeholder="0.00" step="0.01" inputmode="decimal"></div>
    </div>
    <div class="form-row"><label>Artikel / Omschrijving</label><input type="text" id="v-art" placeholder="bijv. Samba OG Maroon"></div>
    <button class="btn btn-teal" onclick="addVinted()">✓ Verkoop toevoegen</button>
  </div>

  <!-- INKOOP -->
  <div class="form-card">
    <div class="form-title">📥 Inkoop toevoegen</div>
    <div class="form-row"><label>Datum</label><input type="date" id="i-datum"></div>
    <div class="form-grid">
      <div class="form-row">
        <label>Categorie</label>
        <select id="i-cat"><option>Schoenen</option><option>Kleding</option><option>Voetbalshirts</option><option>Tassen</option><option>Accessoires</option><option>Overige</option></select>
      </div>
      <div class="form-row">
        <label>Platform</label>
        <select id="i-plat"><option>Basetao</option><option>Pandabuy</option><option>Sugargoo</option><option>Cssbuy</option><option>Andere</option></select>
      </div>
    </div>
    <div class="form-row"><label>Artikel / Omschrijving</label><input type="text" id="i-art" placeholder="bijv. Samba OG Maroon"></div>
    <div class="form-grid">
      <div class="form-row"><label>Maat</label><input type="text" id="i-maat" placeholder="bijv. 39, S, M"></div>
      <div class="form-row"><label>Aantal</label><input type="number" id="i-qty" value="1" min="1" inputmode="numeric"></div>
    </div>
    <div class="form-row"><label>Prijs per stuk (¥)</label><input type="number" id="i-prijs" placeholder="0.00" step="0.01" inputmode="decimal"></div>
    <button class="btn btn-blue" onclick="addInkoop()">✓ Inkoop toevoegen</button>
  </div>

  <!-- SETTINGS -->
  <div class="form-card">
    <div class="form-title">⚙️ Instellingen</div>
    <div class="setting-row">
      <div>
        <div style="font-size:13px;font-weight:600;color:var(--dark)">Wisselkoers</div>
        <div style="font-size:10px;color:var(--greyt)">1 CNY = ? euro</div>
      </div>
      <input class="setting-input" type="number" id="eur-rate" step="0.00001" inputmode="decimal">
    </div>
    <button class="btn btn-blue" onclick="saveRate()">Wisselkoers opslaan</button>
    <button class="btn btn-red" onclick="confirmReset()" style="margin-top:10px">⚠️ Alles resetten naar standaard</button>
  </div>
</div>

<!-- BOTTOM NAV -->
<div class="bottom-nav">
  <div class="tab active" onclick="showPage('overview',this)"><div class="tab-icon">📊</div>Overview</div>
  <div class="tab" onclick="showPage('maanden',this)"><div class="tab-icon">📅</div>Maanden</div>
  <div class="tab" onclick="showPage('inkoop',this)"><div class="tab-icon">📥</div>Inkoop</div>
  <div class="tab" onclick="showPage('vinted',this)"><div class="tab-icon">💰</div>Vinted</div>
  <div class="tab" onclick="showPage('add',this)"><div class="tab-icon">➕</div>Toevoegen</div>
</div>

<!-- DELETE MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <div class="modal-title" id="modal-title">Regel verwijderen?</div>
    <div class="modal-sub" id="modal-sub"></div>
    <div class="modal-btns">
      <button class="btn btn-red" onclick="confirmDelete()">🗑 Verwijderen</button>
      <button class="btn" style="background:var(--grey2);color:var(--dark)" onclick="closeModal()">Annuleren</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

